{
  "version": 2,
  "rewrites": [
    { "source": "/api/skills", "destination": "/api/skills.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" },
        { "key": "Content-Type", "value": "image/svg+xml" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
